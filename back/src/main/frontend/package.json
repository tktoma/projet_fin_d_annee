{
  "name": "back-frontend",
  "version": "1.0.0",
  "description": "Frontend build for Spring Boot application",
  "scripts": {
    "build": "tailwindcss -i ./src/input.css -o ../resources/static/css/output.css --watch",
    "build-prod": "tailwindcss -i ./src/input.css -o ../resources/static/css/output.css --minify"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.1",
    "autoprefixer": "^10.4.18",
    "postcss": "^8.4.35"
  },
  "dependencies": {
    "lucide": "^0.363.0"
  }
}
